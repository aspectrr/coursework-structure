# Course data (MIT OCW downloads) — read-only mount
COURSES_DIR=/courses

# Obsidian vault mount point inside container
NOTES_DIR=/notes

# Daily time budget (minutes)
DAILY_BUDGET_MINUTES=60

# Postgres
POSTGRES_USER=coursework
POSTGRES_PASSWORD=coursework
POSTGRES_DB=coursework
DATABASE_URL=postgres://coursework:coursework@db:5432/coursework

# Optional: YouTube Data API key for auto-fetching lecture durations
# YT_API_KEY=

# Host path for MIT OCW course downloads
COURSES_HOST_DIR=/Users/collinpfeifer/Desktop/learning/courses

# Notes live in ./notes (project-local). Open that folder in Obsidian.
# To keep iCloud sync: symlink the iCloud folder to ./notes on your host:
#   ln -s "/Users/collinpfeifer/Library/Mobile Documents/iCloud~md~obsidian/Documents/Notes/Courses" ./notes
